{
  "manifest_version": 3,
  "name": "Leboncoin Monitor",
  "version": "1.1.0",
  "description": "Reçois des notifications dès qu'une nouvelle annonce apparaît sur leboncoin.",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": ["https://www.leboncoin.fr/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
